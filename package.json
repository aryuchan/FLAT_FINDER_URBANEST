{
  "name": "flatfinder",
  "version": "1.0.0",
  "description": "FlatFinder — Rental Flat Management Platform",
  "type": "module",
  "main": "server.js",
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  },
  "scripts": {
    "start": "NODE_ENV=production node server.js",
    "dev": "node --watch server.js",
    "dev:win": "set NODE_ENV=development && node --watch server.js",
    "lint": "node --check server.js db.js app.js ff-core.js ff-auth.js ff-tenant.js ff-owner.js ff-admin.js"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "compression": "^1.8.1",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "dotenv": "^16.6.1",
    "express": "^4.22.1",
    "express-rate-limit": "^8.3.2",
    "helmet": "^7.2.0",
    "jsonwebtoken": "^9.0.3",
    "lru-cache": "^11.3.5",
    "morgan": "^1.10.1",
    "mysql2": "^3.9.7",
    "winston": "^3.19.0",
    "zod": "^4.3.6",
    "cloudinary": "^2.5.0"
  },
  "keywords": ["flatfinder", "rental", "real-estate", "express", "mysql"],
  "author": "FlatFinder Team",
  "license": "ISC"
}
