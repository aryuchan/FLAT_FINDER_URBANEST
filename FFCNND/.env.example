# ─────────────────────────────────────────────
# FlatFinder — Environment Variables
# Copy this file to .env and fill in your values
# ─────────────────────────────────────────────

# Server
PORT=3000
NODE_ENV=development

# Database (MySQL)
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=NewStrongPassword123
DB_NAME=flatfinder

# JWT Secret — change this to a long random string in production!
JWT_SECRET=change_me_to_a_long_random_secret_string_in_production

# Frontend origin (where your HTML files are served from)
# If using Live Server (VS Code): http://127.0.0.1:5500
# If serving from Express static: http://localhost:3000
FRONTEND_ORIGIN=http://localhost:3000
